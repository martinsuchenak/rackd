# Core settings
DATA_DIR=./data
LISTEN_ADDR=:8080
API_AUTH_TOKEN=your-secret-token
MCP_AUTH_TOKEN=your-mcp-token
LOG_FORMAT=text
LOG_LEVEL=info

# Security (both enabled by default — disable for local dev over plain HTTP)
COOKIE_SECURE=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Set to false when developing locally without TLS
# COOKIE_SECURE=false

# Discovery
DISCOVERY_INTERVAL=24h
DISCOVERY_MAX_CONCURRENT=10
DISCOVERY_TIMEOUT=5s
DISCOVERY_CLEANUP_DAYS=30
DISCOVERY_SCAN_ON_STARTUP=false
