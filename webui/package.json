{
  "name": "rackd-webui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run build --watch",
    "build": "bun run build:css && bun run build:js && bun run build:html && bun run build:assets",
    "build:css": "bunx @tailwindcss/cli -c ./tailwind.config.js -i ./src/styles.css -o ./dist/output.css --minify",
    "build:js": "bun build ./src/app.ts --outdir ./dist --minify",
    "build:html": "bun run ./scripts/build-html.ts",
    "build:assets": "cp -r ./assets/* ./dist/ 2>/dev/null || true && rm -rf ../internal/ui/assets/* && cp -r ./dist/* ../internal/ui/assets/",
    "test": "bun test",
    "test:e2e": "bun run build && playwright test",
    "test:e2e:auth": "bun run build && playwright test --grep @auth",
    "test:e2e:dns": "bun run build && playwright test --grep @dns",
    "test:e2e:discovery": "bun run build && playwright test --grep @discovery",
    "test:e2e:headed": "bun run build && playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:modal": "bun run build && playwright test --grep @modal",
    "test:e2e:rbac": "bun run build && playwright test --grep @rbac",
    "test:e2e:slow": "bun run build && playwright test --grep @slow",
    "test:e2e:smoke": "bun run build && playwright test --grep @smoke",
    "typecheck": "bunx tsc --noEmit",
    "validate:types": "bun run ./scripts/validate-openapi-types.ts"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.11",
    "@alpinejs/csp": "^3.15.11",
    "@alpinejs/focus": "^3.15.11",
    "alpinejs": "^3.15.11",
    "cytoscape": "^3.33.2",
    "cytoscape-panzoom": "^2.5.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/cli": "^4.2.2",
    "@types/alpinejs": "^3.13.11",
    "posthtml": "^0.16.7",
    "posthtml-include": "^2.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
