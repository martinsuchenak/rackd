{
  "name": "rackd-webui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run build --watch",
    "build": "bun run build:css && bun run build:js",
    "build:css": "bunx @tailwindcss/cli -i ./src/styles.css -o ./dist/output.css --minify",
    "build:js": "bun build ./src/app.ts --outdir ./dist --minify",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "alpinejs": "^3.14.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/alpinejs": "^3.13.11",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
